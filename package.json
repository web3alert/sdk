{
  "name": "@web3alert/sdk",
  "version": "3.4.3",
  "description": "TypeScript SDK for building distributed microservices and event-driven applications on NATS",
  "author": "Web3alert Team <info@web3alert.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web3alert/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/web3alert/sdk/issues"
  },
  "homepage": "https://github.com/web3alert/sdk#readme",
  "keywords": [
    "web3",
    "web3alert",
    "sdk",
    "nats",
    "jetstream",
    "microservices",
    "distributed",
    "event-driven",
    "messaging",
    "pubsub",
    "blockchain",
    "typescript"
  ],
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run clean && tsc",
    "clean": "rm -rf dist",
    "test": "npm run build && npm run test:types && node --test test/public-entrypoint.test.cjs",
    "test:types": "tsc -p tsconfig.test.json",
    "verify:package": "node scripts/verify-package.cjs",
    "prepublishOnly": "npm test && npm run verify:package"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cron-parser": "^4.9.0",
    "eventemitter3": "^5.0.1",
    "fast-json-stable-stringify": "^2.1.0",
    "fastq": "^1.17.1",
    "lodash": "^4.18.1",
    "nanoid": "^3.3.8",
    "nats": "^2.28.2",
    "prom-client": "^15.1.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.6",
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5"
  }
}
